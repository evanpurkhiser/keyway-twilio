{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "keyway",
  "version": "1.0.0",
  "license": "MIT",
  "main": "index.js",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "prestart": "tsc",
    "start": "twilio-run start",
    "predeploy": "tsc",
    "deploy": "twilio-run deploy ",
    "activate": "twilio-run activate --source-environment=dev --create-environment --production",
    "lint": "oxlint src/",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@sentry/node": "^7.36.0",
    "node-fetch": "^2.6.9",
    "twilio": "^3.84.1"
  },
  "devDependencies": {
    "@evanpurkhiser/oxc-config": "^0.8.0",
    "@twilio-labs/serverless-runtime-types": "^2.2.3",
    "@types/node-fetch": "^2.5.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "twilio-run": "^3.5.3",
    "typescript": "^4.9.5"
  },
  "volta": {
    "node": "24.0.0"
  },
  "twilioserverless": {
    "runtime": "node16",
    "overrideExistingProject": true
  }
}
